#!/usr/bin/env bash
# Agent Task Monitor for {{PROJECT_DISPLAY_NAME}}
# Polls the server for task state changes and routes them.
# Runs via launchd every 60 seconds.

set -euo pipefail

PROJECT_DIR="{{LOCAL_PROJECT_DIR}}"
STATE_FILE="$PROJECT_DIR/.monitor-state"
LOG_FILE="$PROJECT_DIR/log/monitor.log"
REMOTE="{{SERVER_HOST}}"
REMOTE_FILE="{{SERVER_HOME}}/notifications.jsonl"
ACTION="$PROJECT_DIR/bin/{{PROJECT_NAME}}-action"

log() {
  echo "$(date '+%Y-%m-%d %H:%M:%S') $1" >> "$LOG_FILE"
}

notify() {
  local title="$1"
  local message="$2"
  local sound="${3:-default}"
  osascript -e "display notification \"$message\" with title \"$title\" sound name \"$sound\""
}

# Read last position (byte offset into remote file)
if [[ -f "$STATE_FILE" ]]; then
  LAST_OFFSET=$(cat "$STATE_FILE")
else
  LAST_OFFSET=$(ssh -o ConnectTimeout=10 "$REMOTE" "wc -c < '$REMOTE_FILE' 2>/dev/null || echo 0")
  echo "$LAST_OFFSET" > "$STATE_FILE"
  log "First run — starting from offset $LAST_OFFSET"
  exit 0
fi

# Fetch new lines from the remote notifications file starting at our offset
NEW_DATA=$(ssh -o ConnectTimeout=10 "$REMOTE" "tail -c +$((LAST_OFFSET + 1)) '$REMOTE_FILE' 2>/dev/null" || true)

if [[ -z "$NEW_DATA" ]]; then
  exit 0
fi

# Update offset to current file size
NEW_OFFSET=$(ssh -o ConnectTimeout=10 "$REMOTE" "wc -c < '$REMOTE_FILE' 2>/dev/null || echo $LAST_OFFSET")
echo "$NEW_OFFSET" > "$STATE_FILE"

# Process each event line
while IFS= read -r line; do
  [[ -z "$line" ]] && continue

  EVENT=$(echo "$line" | python3 -c "import sys,json; print(json.loads(sys.stdin.read()).get('event',''))" 2>/dev/null || echo "")
  TASK_ID=$(echo "$line" | python3 -c "import sys,json; print(json.loads(sys.stdin.read()).get('task_id',''))" 2>/dev/null || echo "")
  TITLE=$(echo "$line" | python3 -c "import sys,json; print(json.loads(sys.stdin.read()).get('title',''))" 2>/dev/null || echo "")
  PROJECT=$(echo "$line" | python3 -c "import sys,json; print(json.loads(sys.stdin.read()).get('project',''))" 2>/dev/null || echo "")

  if [[ "$EVENT" == "completed" ]]; then
    log "COMPLETED: Task #$TASK_ID ($TITLE) in $PROJECT"
    notify "Task Completed" "#$TASK_ID: $TITLE — click menu bar to review" "Glass"

  elif [[ "$EVENT" == "blocked" ]]; then
    log "BLOCKED: Task #$TASK_ID ($TITLE) in $PROJECT — auto-triaging..."

    # Check what's blocking it
    OUTPUT=$(ssh -o ConnectTimeout=10 "$REMOTE" "ty output $TASK_ID 2>&1 | tail -20" || echo "")

    # Permission/commit/push prompts — send input to get past them
    if echo "$OUTPUT" | grep -qiE "(permission|allow|approve|yes/no|Y/n|\[Y\]|\? \(y\)|bypass permissions|push it|commit this|create a PR)"; then
      log "  -> Permission prompt detected, sending input to task #$TASK_ID"
      ssh -o ConnectTimeout=10 "$REMOTE" "ty input $TASK_ID --enter" 2>&1 >> "$LOG_FILE" || true

    # Dead pane — retry (no session to send input to)
    elif echo "$OUTPUT" | grep -qiE "(pane may not exist|no server running)"; then
      log "  -> Dead session, retrying task #$TASK_ID"
      ssh -o ConnectTimeout=10 "$REMOTE" "ty retry $TASK_ID" 2>&1 >> "$LOG_FILE" || true

    # Something else — route to GM
    else
      log "  -> Needs GM attention, routing to {{GM_ALIAS}}"
      "$ACTION" blocked "$TASK_ID" &
      notify "Task Blocked" "#$TASK_ID: $TITLE" "Basso"
    fi

  else
    log "UNKNOWN EVENT: $line"
  fi

done <<< "$NEW_DATA"
