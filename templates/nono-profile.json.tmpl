{
  "meta": {
    "name": "taskyou-agent",
    "version": "1.0.0",
    "description": "TaskYou agent sandbox with credential isolation"
  },
  "security": {
    "groups": ["claude-code", "node_runtime"]
  },
  "workdir": {
    "access": "readwrite"
  },
  "filesystem": {
    "allow": ["$HOME/projects"],
    "read": [
      "$HOME/.config/task",
      "$HOME/.claude",
      "$HOME/.local/share/task"
    ]
  },
  "network": {
    "block": false
  }
}
