{
  "meta": {
    "name": "taskyou-agent",
    "version": "1.0.0",
    "description": "TaskYou agent sandbox with credential isolation",
    "extends": "claude-code"
  },
  "workdir": {
    "access": "readwrite"
  },
  "filesystem": {
    "read": [
      "$HOME/.config/task",
      "$HOME/.claude",
      "$HOME/.local/share/task"
    ]
  },
  "network": {
    "block": false
  }
}
