[Unit]
Description=TaskYou daemon
After=network.target

[Service]
Type=simple
Environment="PATH=%h/bin:%h/.local/bin:%h/.npm-global/bin:/usr/local/bin:/usr/bin:/bin"
ExecStart=%h/.local/bin/ty daemon --dangerous
Restart=on-failure
RestartSec=5
StandardOutput=append:%h/log/ty-daemon.log
StandardError=append:%h/log/ty-daemon.log

[Install]
WantedBy=default.target
