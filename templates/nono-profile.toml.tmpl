[meta]
name = "taskyou-agent"
extends = "claude-code"
description = "TaskYou agent sandbox with credential isolation"

[filesystem]
# Agents can read/write project worktrees
allow = ["$HOME/projects"]

# Agents can read TaskYou config, hooks, and Claude config
read = [
    "$HOME/.config/task",
    "$HOME/.claude",
    "$HOME/.local/share/task"
]

[workdir]
sharing = "readwrite"
