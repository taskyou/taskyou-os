#!/usr/bin/env bash
# TaskYou hook: fires when a task starts executing
# Pre-accepts Claude trust dialog for the worktree directory so agents
# don't get stuck on interactive prompts.

CLAUDE_JSON="$HOME/.claude.json"
WORKTREE_PATH="${WORKTREE_PATH:-}"

# Fallback: if WORKTREE_PATH not provided, find it from TASK_ID + TASK_PROJECT
if [[ -z "$WORKTREE_PATH" && -n "${TASK_ID:-}" && -n "${TASK_PROJECT:-}" ]]; then
  DATA_DIR="$HOME/.local/share/task/${TASK_PROJECT}"
  # Find the worktree directory matching this task ID
  for dir in "$DATA_DIR"/.task-worktrees/"${TASK_ID}"-*/; do
    [[ -d "$dir" ]] && WORKTREE_PATH="${dir%/}" && break
  done
fi

[[ -z "$WORKTREE_PATH" ]] && exit 0
[[ ! -f "$CLAUDE_JSON" ]] && exit 0

# Quick check: if this path is already trusted, skip
grep -q "\"$WORKTREE_PATH\"" "$CLAUDE_JSON" 2>/dev/null && exit 0

# Inject trust — use jq if available, fall back to sed
if command -v jq &>/dev/null; then
  tmp=$(mktemp)
  jq --arg p "$WORKTREE_PATH" '.projects[$p] = (.projects[$p] // {} | .hasTrustDialogAccepted = true | .hasCompletedProjectOnboarding = true)' "$CLAUDE_JSON" > "$tmp" && mv "$tmp" "$CLAUDE_JSON"
else
  # Minimal sed: insert trust entry before the closing brace of "projects"
  # This is a fallback — jq is strongly preferred
  sed -i 's|"projects": {|"projects": {\n    "'"$WORKTREE_PATH"'": {"hasTrustDialogAccepted":true,"hasCompletedProjectOnboarding":true},|' "$CLAUDE_JSON"
fi
